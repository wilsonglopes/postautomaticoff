# ============================================================
# Supabase
# ============================================================
# URL pública do projeto Supabase (pode ir ao front-end)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave anônima (pode ir ao front-end)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço (SOMENTE no servidor - nunca no front-end)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# WordPress (feltrofacil.com.br)
# ============================================================
# URL base do WordPress SEM barra final
WP_BASE_URL=https://feltrofacil.com.br

# Usuário do WordPress com permissão de editor/admin
WP_USERNAME=seu_usuario

# Application Password gerado em: WP Admin > Usuários > Perfil > Senhas de Aplicativo
# Formato: xxxx xxxx xxxx xxxx xxxx xxxx
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================================
# Aplicação
# ============================================================
# URL pública da aplicação (usado para redirects e links)
NEXT_PUBLIC_APP_URL=https://seu-projeto.netlify.app

# ============================================================
# Integrações futuras (IA para geração de conteúdo)
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
